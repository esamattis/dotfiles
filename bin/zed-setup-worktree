#!/usr/bin/env bash

set -eux

changed_paths="$(mktemp)"
trap 'rm -f "$changed_paths"' EXIT

git -C "$ZED_MAIN_GIT_WORKTREE" diff --name-only --diff-filter=d -z HEAD -- > "$changed_paths"
git -C "$ZED_MAIN_GIT_WORKTREE" ls-files --others --exclude-standard -z -- >> "$changed_paths"

if [ -s "$changed_paths" ]; then
  rsync -a --from0 --files-from="$changed_paths" "$ZED_MAIN_GIT_WORKTREE/" "$ZED_WORKTREE_ROOT/"
fi

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
local_setup_script="$script_dir/zed-setup-worktree-local"

if [ -x "$local_setup_script" ]; then
  "$local_setup_script"
fi
