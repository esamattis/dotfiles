#!/bin/sh

set -eu

usage() {
    >&2 echo "usage: ,git-sync [--push-back|-b] <remote> [branch]"
    >&2 echo
    >&2 echo "Fetch a remote branch and hard-reset a local branch to match it."
    >&2 echo "Or, with --push-back/-b, force-push the local branch back to the remote branch."
    >&2 echo
    >&2 echo "Reset behavior:"
    >&2 echo "  1. Run 'git fetch <remote>'."
    >&2 echo "  2. Use [branch], or default to the current local branch."
    >&2 echo "  3. Exit if <remote>/<branch> does not exist after fetch."
    >&2 echo "  4. Exit early if [branch] already matches <remote>/<branch>."
    >&2 echo "  5. If not currently on [branch], switch to it, or create it first."
    >&2 echo "  6. Ask for confirmation before 'git reset --hard <remote>/<branch>'."
    >&2 echo
    >&2 echo "Push-back behavior:"
    >&2 echo "  1. Use [branch], or default to the current local branch."
    >&2 echo "  2. Exit early if [branch] already matches <remote>/<branch>."
    >&2 echo "  3. Ask for confirmation before 'git push -f <remote> <branch>:<branch>'."
    >&2 echo "  4. Tip: run this on the remote first, or the push might fail:"
    >&2 echo "     git config receive.denyCurrentBranch ignore"
    >&2 echo
    >&2 echo "Examples:"
    >&2 echo "  ,git-sync origin"
    >&2 echo "  ,git-sync origin main"
    >&2 echo "  ,git-sync --push-back origin"
    >&2 echo "  ,git-sync -b origin main"
}

if [ "${1-}" = "-h" ] || [ "${1-}" = "--help" ]; then
    usage
    exit 0
fi

push_back=0

while [ $# -gt 0 ]; do
    case "$1" in
        -b|--push-back)
            push_back=1
            shift
            ;;
        --)
            shift
            break
            ;;
        -*)
            >&2 echo "Unknown option: $1"
            usage
            exit 1
            ;;
        *)
            break
            ;;
    esac
done

if [ $# -lt 1 ] || [ $# -gt 2 ]; then
    usage
    exit 1
fi

remote="$1"
branch="${2-}"

if [ -z "$branch" ]; then
    branch="$(git branch --show-current)"

    if [ -z "$branch" ]; then
        >&2 echo "Could not determine current branch"
        exit 1
    fi
fi

git fetch "$remote"

same_commit() {
    [ "$(git rev-parse "$1")" = "$(git rev-parse "$2")" ]
}

if [ "$push_back" -eq 1 ]; then
    if git show-ref --verify --quiet "refs/heads/$branch" \
        && git show-ref --verify --quiet "refs/remotes/$remote/$branch" \
        && same_commit "refs/heads/$branch" "refs/remotes/$remote/$branch"; then
        echo "Already in sync: '$branch' matches '$remote/$branch'."
        exit 0
    fi

    >&2 echo "WARNING: this will force-push local '$branch' to '$remote/$branch'."
    >&2 echo "This can overwrite remote history."
    >&2 echo "Tip: run this on the remote first, or the push might fail:"
    >&2 echo "  git config receive.denyCurrentBranch ignore"
    printf "type 'back' to continue> "
    read response

    if [ "$response" != "back" ]; then
        >&2 echo "Abort."
        exit 1
    fi

    git push -f "$remote" "$branch:$branch"
    exit 0
fi


if ! git show-ref --verify --quiet "refs/remotes/$remote/$branch"; then
    >&2 echo "Remote branch does not exist: $remote/$branch"
    exit 1
fi

if git show-ref --verify --quiet "refs/heads/$branch" \
    && same_commit "refs/heads/$branch" "refs/remotes/$remote/$branch"; then
    echo "Already in sync: '$branch' matches '$remote/$branch'."
    exit 0
fi

current_branch="$(git branch --show-current)"

if [ "$current_branch" != "$branch" ]; then
    if git show-ref --verify --quiet "refs/heads/$branch"; then
        git switch "$branch"
    else
        git switch -c "$branch"
    fi
fi

target="$remote/$branch"
target_commit="$(git log -1 --format='%h %s' "$target")"
target_commit_age="$(git log -1 --format='%cr' "$target")"

>&2 echo "WARNING: this will discard local changes."
>&2 echo "Reset target: '$branch' -> '$target'"
>&2 echo "Target commit: $target_commit"
>&2 echo "Commit age: $target_commit_age"
printf "type 'reset' to continue> "
read response

if [ "$response" != "reset" ]; then
    >&2 echo "Abort."
    exit 1
fi

git reset --hard "$target"
