#!/bin/sh

set -eu

CLIP=$(printf '\n\n```%s#%s\n%s\n```\n\n' "$ZED_RELATIVE_FILE" "$ZED_ROW" "$ZED_SELECTED_TEXT")
echo "$CLIP" | pbcopy

CLIP_FILE="$TMPDIR/zed-combined-clipboard.txt"

if [ -f "$CLIP_FILE" ]; then
    FILE_AGE=$(( $(date +%s) - $(stat -f %m "$CLIP_FILE") ))
    if [ "$FILE_AGE" -gt 7200 ]; then
        rm "$CLIP_FILE"
    fi
fi

EXISTING=$(cat "$CLIP_FILE" 2>/dev/null || true)
case "$EXISTING" in
    *"$CLIP"*) ;;
    *) printf '%s\n' "$CLIP" >> "$CLIP_FILE" ;;
esac
