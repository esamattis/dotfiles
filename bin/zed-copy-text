#!/bin/sh

set -eu

CLIP=$(printf '\n\n```%s#%s\n%s\n```\n\n' "$ZED_RELATIVE_FILE" "$ZED_ROW" "$ZED_SELECTED_TEXT")
echo "$CLIP" | pbcopy

EXISTING=$(cat "$TMPDIR/zed-combined-clipboard.txt" 2>/dev/null || true)
case "$EXISTING" in
    *"$CLIP"*) ;;
    *) printf '%s\n' "$CLIP" >> "$TMPDIR/zed-combined-clipboard.txt" ;;
esac
