#!/bin/sh


# https://news.ycombinator.com/item?id=11071754

set -eu

repo="git@github.com:esamattis/homegit.git"
git_dir="${HOME}/.homegit"
tmp_dir="${HOME}/.homegit-tmp"

usage() {
    >&2 echo "usage: ,install-homegit [repo]"
    >&2 echo
    >&2 echo "Install a bare homegit repository at \$HOME/.homegit."
    >&2 echo "Default repo: ${repo}"
}

if [ "${1-}" = "-h" ] || [ "${1-}" = "--help" ]; then
    usage
    exit 0
fi

if [ $# -gt 1 ]; then
    usage
    exit 1
fi

if [ $# -eq 1 ]; then
    repo="$1"
fi

if ! command -v git >/dev/null 2>&1; then
    >&2 echo "git is required"
    exit 1
fi

if [ -e "$git_dir" ]; then
    >&2 echo "Already exists: $git_dir"
    exit 1
fi

if [ -e "$tmp_dir" ]; then
    >&2 echo "Temporary checkout already exists: $tmp_dir"
    >&2 echo "Remove it and re-run this script if it is safe to delete."
    exit 1
fi

cleanup() {
    rm -rf "$tmp_dir"
}
trap cleanup EXIT HUP INT TERM

git clone --separate-git-dir="$git_dir" "$repo" "$tmp_dir"
git --git-dir="$git_dir" --work-tree="$HOME" config status.showUntrackedFiles no
cleanup
trap - EXIT HUP INT TERM

git --git-dir="$git_dir" --work-tree="$HOME" status --short
