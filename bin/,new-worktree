#!/bin/sh

set -eu

if [ "${1-}" = "-h" ] || [ "${1-}" = "--help" ]; then
    echo "Create a new worktree on a fresh branch."
    echo "Runs zed-setup-worktree after creating the worktree."
    echo "The temporary branch name is derived from the worktree name."
    exit 0
fi

toplevel="$(git rev-parse --show-toplevel 2>/dev/null)" || {
    echo "Not in a git repository" >&2
    exit 1
}
cd "$toplevel"

common_dir="$(git rev-parse --git-common-dir 2>/dev/null)"
if [ -z "$common_dir" ]; then
    echo "Not in a git repository" >&2
    exit 1
fi

base_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"
if [ -z "$base_branch" ] || [ "$base_branch" = "HEAD" ]; then
    echo "Could not determine current branch" >&2
    exit 1
fi

worktree_name="${1-}"
if [ -z "$worktree_name" ]; then
    printf "Worktree name> "
    IFS= read -r worktree_name
fi

if [ -z "$worktree_name" ]; then
    echo "Worktree name is required" >&2
    exit 1
fi

sanitized_name="$(printf "%s" "$worktree_name" | tr '[:upper:]' '[:lower:]' | tr '[:space:]' '_')"
if [ -z "$sanitized_name" ]; then
    echo "Worktree name is empty after sanitizing" >&2
    exit 1
fi

branch_ref_exists() {
    git show-ref --verify --quiet "refs/heads/$1" && return 0
    git show-ref --verify --quiet "refs/remotes/origin/$1" && return 0
    return 1
}

worktree_branch="${sanitized_name}"
if branch_ref_exists "$worktree_branch"; then
    branch_found=""
    i=2
    while [ "$i" -le 10 ]; do
        candidate_branch="${sanitized_name}-$i"
        if ! branch_ref_exists "$candidate_branch"; then
            worktree_branch="$candidate_branch"
            branch_found=1
            break
        fi
        i=$((i + 1))
    done

    if [ -z "$branch_found" ]; then
        echo "Could not find an unused branch name for $sanitized_name (tried up to -10)" >&2
        exit 1
    fi
fi

worktree_dirname="$worktree_branch"

# Resolve the original repo root from common_dir (.git dir), so this works
# even when run from inside an existing worktree.
abs_common_dir="$(cd "$common_dir" && pwd)"
original_repo="$(dirname "$abs_common_dir")"
original_repo_dirname="$(basename "$original_repo")"
worktrees_root="${original_repo}/../worktrees/${original_repo_dirname}"

mkdir -p "$worktrees_root"

worktree_path="$(cd "$worktrees_root" && pwd)/${worktree_dirname}"

if ! git worktree add -b "$worktree_branch" "$worktree_path" "$base_branch"; then
    echo "Failed to create worktree at $worktree_path from new branch $worktree_branch based on $base_branch" >&2
    exit 1
fi

if [ -f "$original_repo/.envrc" ]; then
    cp "$original_repo/.envrc" "$worktree_path/.envrc"

    if command -v direnv >/dev/null 2>&1; then
        (cd "$worktree_path" && direnv allow)
    fi
fi

ZED_MAIN_GIT_WORKTREE="$original_repo" \
ZED_WORKTREE_ROOT="$worktree_path" \
    zed-setup-worktree

echo
echo
echo
echo "$worktree_path"
